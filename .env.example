# Supabase (public - safe for client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-only - never expose)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Prisma - direct Postgres connection string)
DATABASE_URL=postgresql://user:password@host:5432/database?schema=public

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@workforceap.org

# Optional: Sentry (error monitoring) - add @sentry/nextjs and configure
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Optional: Turnstile/ReCAPTCHA (bot defense)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
