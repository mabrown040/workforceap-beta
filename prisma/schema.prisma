// WorkforceAP Members Portal - Prisma Schema
// Database: Supabase Postgres (POSTGRES_PRISMA_URL from Vercel integration, or DATABASE_URL for local)
// Auth: Supabase Auth (auth.users) - our users.id matches auth.users.id

generator client {
  provider = "prisma-client-js"
}

// Run with: npm run db:seed
// To promote a user to admin: INSERT INTO user_roles (user_id, role_id) SELECT '<user_id>', id FROM roles WHERE name = 'admin';

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// --- Core tables ---

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String   @map("full_name")
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile            Profile?
  applications        Application[]
  jobApplications     JobApplication[]
  benefitRequests     BenefitRequest[]
  learningProgress    LearningProgress[]
  aiToolResults       AIToolResult[]
  userRoles           UserRole[]
  auditLogs           AuditLog[] @relation("ActorAuditLogs")

  @@map("users")
}

model Profile {
  id                   String    @id @default(uuid())
  userId               String    @unique @map("user_id")
  address              String?
  city                 String?
  state                String?
  zip                  String?
  dob                  DateTime? @db.Date
  veteranStatus        String?   @map("veteran_status")
  employmentStatus     String?   @map("employment_status")
  consentTerms         Boolean   @default(false) @map("consent_terms")
  consentCommunications Boolean  @default(false) @map("consent_communications")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Application {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  status         ApplicationStatus @default(PENDING)
  programInterest String  @map("program_interest")
  notes          String?  @db.Text
  submittedAt    DateTime? @map("submitted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("applications")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  DENIED
  NEEDS_INFO
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique // member, admin, case_manager
  createdAt DateTime @default(now()) @map("created_at")

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Resource {
  id             String   @id @default(uuid())
  title          String
  type           ResourceType
  url            String?
  path           String?
  visibilityRule String?  @map("visibility_rule") // e.g. "member", "admin", "case_manager"
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("resources")
}

enum ResourceType {
  DOCUMENT
  VIDEO
  LINK
}

model JobApplication {
  id          String              @id @default(uuid())
  userId      String              @map("user_id")
  company     String
  role        String
  status      JobApplicationStatus @default(SAVED)
  appliedAt   DateTime?           @map("applied_at")
  notes       String?             @db.Text
  url         String?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("job_applications")
}

enum JobApplicationStatus {
  SAVED
  APPLIED
  INTERVIEWING
  OFFER
  REJECTED
}

model BenefitRequest {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  benefit   String   // linkedin_premium, coursera
  status    BenefitRequestStatus @default(PENDING)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, benefit])
  @@index([userId])
  @@index([status])
  @@map("benefit_requests")
}

enum BenefitRequestStatus {
  PENDING
  APPROVED
  DENIED
}

model LearningProgress {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  pathwayId  String   @map("pathway_id")
  completed  Boolean  @default(false)
  progress   Int      @default(0) // 0-100
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pathwayId])
  @@index([userId])
  @@map("learning_progress")
}

model AIToolResult {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  toolType     AIToolType   @map("tool_type")
  inputSummary String       @map("input_summary")
  output       String       @db.Text
  createdAt    DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, toolType])
  @@map("ai_tool_results")
}

enum AIToolType {
  resume_rewriter
  cover_letter
  interview_practice
  linkedin_headline
}

model AuditLog {
  id           String   @id @default(uuid())
  actorUserId  String?  @map("actor_user_id")
  action       String
  targetType   String   @map("target_type")
  targetId     String?  @map("target_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  actor User? @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}
