{
  "name": "workforceap",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/safe-migrate.cjs && node scripts/prisma-env.js prisma generate && next build",
    "postinstall": "node scripts/prisma-env.js prisma generate",
    "start": "next start",
    "db:generate": "node scripts/prisma-env.js prisma generate",
    "db:migrate": "node scripts/prisma-env.js prisma migrate dev",
    "db:migrate:deploy": "node scripts/prisma-env.js prisma migrate deploy",
    "db:push": "node scripts/prisma-env.js prisma db push",
    "db:studio": "node scripts/prisma-env.js prisma studio",
    "db:seed": "node scripts/prisma-env.js npx tsx prisma/seed.ts",
    "db:seed:blog": "node scripts/prisma-env.js npx tsx prisma/seed-blog.ts",
    "db:create-employer-michael-brown": "node scripts/prisma-env.js npx tsx scripts/create-employer-michael-brown.ts",
    "db:migrate:resolve-failed": "node scripts/resolve-failed-migration.cjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "repo:sync-master": "powershell -ExecutionPolicy Bypass -File scripts/auto-sync-master.ps1"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^5.22.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@upstash/ratelimit": "^2.0.4",
    "@upstash/redis": "^1.34.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "groq-sdk": "^1.1.1",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "next": "^15",
    "pdf-parse": "^1.1.1",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^4.0.1",
    "undici": "^7.24.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
