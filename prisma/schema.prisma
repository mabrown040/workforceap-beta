// WorkforceAP Members Portal - Prisma Schema
// Database: Supabase Postgres (POSTGRES_PRISMA_URL from Vercel integration, or DATABASE_URL for local)
// Auth: Supabase Auth (auth.users) - our users.id matches auth.users.id

generator client {
  provider = "prisma-client-js"
}

// Run with: npm run db:seed
// To promote a user to admin: INSERT INTO user_roles (user_id, role_id) SELECT '<user_id>', id FROM roles WHERE name = 'admin';

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// --- Core tables ---

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  fullName               String    @map("full_name")
  phone                  String?
  assessmentCompleted    Boolean   @default(false) @map("assessment_completed")
  assessmentCompletedAt  DateTime? @map("assessment_completed_at")
  assessmentScore        Int?      @map("assessment_score")
  assessmentScorePct     Int?      @map("assessment_score_pct")
  programInterest        String?   @map("program_interest")
  assessmentAnswers      Json?     @map("assessment_answers")
  enrolledProgram        String?   @map("enrolled_program")
  enrolledAt             DateTime? @map("enrolled_at")
  programChangedAt       DateTime? @map("program_changed_at")
  coursesCompleted       Json?     @map("courses_completed") // array of course slugs
  notificationsUpdates   Boolean   @default(true) @map("notifications_updates")
  notificationsReminders Boolean   @default(true) @map("notifications_reminders")
  deletedAt              DateTime? @map("deleted_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  profile              Profile?
  readinessChecklist   ReadinessChecklist[]
  applications         Application[]
  jobApplications      JobApplication[]
  benefitRequests      BenefitRequest[]
  learningProgress     LearningProgress[]
  aiToolResults        AIToolResult[]
  userCertifications   UserCertification[]
  userRoles            UserRole[]
  auditLogs            AuditLog[] @relation("ActorAuditLogs")
  goals                Goal[]
  resourceProgress     ResourceProgress[]
  memberEvents         MemberEvent[]
  weeklyRecaps         WeeklyRecap[]
  pathwayStepProgress  PathwayStepProgress[]
  trainingAccessRequests TrainingAccessRequest[]
  invitationsSent      Invitation[] @relation("InvitationInviter")
  invitationsAccepted  Invitation[] @relation("InvitationAccepter")

  counselorProfile     Counselor?
  counselorAssignments CounselorAssignment[] @relation("MemberAssignments")
  partnerReferrals     PartnerReferral[]     @relation("MemberReferrals")
  placementRecord    PlacementRecord?
  counselorNotes     CounselorNote[]  @relation("MemberNotes")
  notesAuthored      CounselorNote[]  @relation("NoteAuthor")
  partnerUser        PartnerUser?
  employer           Employer?

  jobPostingApplications JobPostingApplication[]
  aiJobMatches       AIJobMatch[]
  jobsApproved       Job[]            @relation("JobApprover")

  subgroupsLed       Subgroup[]       @relation("SubgroupLeader")
  subgroupsCreated   Subgroup[]       @relation("SubgroupCreator")
  memberSubgroups    MemberSubgroup[]
  memberSubgroupsAssigned MemberSubgroup[] @relation("MemberSubgroupAssigner")
  subgroupLeaderRows SubgroupLeader[]

  @@map("users")
}

model Profile {
  id                    String    @id @default(uuid())
  userId                String    @unique @map("user_id")
  address               String?
  city                  String?
  state                 String?
  zip                   String?
  profilePhone          String?   @map("profile_phone")
  profileAddress        String?   @map("profile_address")
  profileLinkedin       String?   @map("profile_linkedin")
  profileBio            String?   @map("profile_bio")
  dob                   DateTime? @db.Date
  veteranStatus         String?   @map("veteran_status")
  employmentStatus      String?   @map("employment_status")
  educationLevel        String?   @map("education_level")
  householdIncome       String?   @map("household_income")
  referralSource        String?   @map("referral_source")
  usCitizen             Boolean?  @map("us_citizen")
  authorizedToWork      Boolean?  @map("authorized_to_work")
  hasDisability         Boolean?  @map("has_disability")
  ethnicity             String?   @map("ethnicity")
  counselorNotes        String?   @map("counselor_notes") @db.Text
  resumeOriginalPath    String?   @map("resume_original_path")
  resumeEnhancedPath    String?   @map("resume_enhanced_path")
  consentTerms          Boolean   @default(false) @map("consent_terms")
  consentCommunications Boolean   @default(false) @map("consent_communications")
  smsOptIn              Boolean   @default(false) @map("sms_opt_in")
  role                  String    @default("member")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model ReadinessChecklist {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  section      Int       // 1–13
  itemKey      String    @map("item_key")
  completed    Boolean   @default(false)
  completedAt  DateTime? @map("completed_at")
  completedBy  String?   @map("completed_by") // counselor user_id
  notes        String?   @db.Text
  valueText    String?   @map("value_text") @db.Text // for free-text fields (job titles, elevator pitch, etc.)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemKey])
  @@index([userId])
  @@map("readiness_checklist")
}

model Application {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  status         ApplicationStatus @default(PENDING)
  programInterest String  @map("program_interest")
  notes          String?  @db.Text
  submittedAt    DateTime? @map("submitted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("applications")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  DENIED
  NEEDS_INFO
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique // member, admin, case_manager
  createdAt DateTime @default(now()) @map("created_at")

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Resource {
  id             String   @id @default(uuid())
  title          String
  type           ResourceType
  url            String?
  path           String?
  visibilityRule String?  @map("visibility_rule") // e.g. "member", "admin", "case_manager"
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("resources")
}

enum ResourceType {
  DOCUMENT
  VIDEO
  LINK
}

model JobApplication {
  id          String              @id @default(uuid())
  userId      String              @map("user_id")
  company     String
  role        String
  status      JobApplicationStatus @default(SAVED)
  appliedAt   DateTime?           @map("applied_at")
  notes       String?             @db.Text
  url         String?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("job_applications")
}

enum JobApplicationStatus {
  SAVED
  APPLIED
  PHONE_SCREEN
  INTERVIEWING
  OFFER
  REJECTED
}

model BenefitRequest {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  benefit   String   // linkedin_premium, coursera
  status    BenefitRequestStatus @default(PENDING)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, benefit])
  @@index([userId])
  @@index([status])
  @@map("benefit_requests")
}

enum BenefitRequestStatus {
  PENDING
  APPROVED
  DENIED
}

model LearningProgress {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  pathwayId  String   @map("pathway_id")
  completed  Boolean  @default(false)
  progress   Int      @default(0) // 0-100
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pathwayId])
  @@index([userId])
  @@map("learning_progress")
}

model Goal {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  goalType         String    @map("goal_type") // build_resume, practice_interviews, apply_to_jobs, etc.
  title            String
  description      String?   @db.Text
  targetMetricType String?   @map("target_metric_type")
  targetMetricValue Int?     @map("target_metric_value")
  currentMetricValue Int     @default(0) @map("current_metric_value")
  status           GoalStatus @default(ACTIVE)
  targetDate       DateTime? @map("target_date")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("goals")
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

model ResourceProgress {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  resourceId     String    @map("resource_id") // matches content id e.g. ats-resume-template
  viewedAt       DateTime? @map("viewed_at")
  completedAt    DateTime? @map("completed_at")
  downloadedAt   DateTime? @map("downloaded_at")
  savedAt       DateTime?  @map("saved_at")
  viewCount      Int       @default(0) @map("view_count")
  completionStatus String  @default("not_started") @map("completion_status") // not_started, in_progress, completed
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@index([resourceId])
  @@map("resource_progress")
}

model MemberEvent {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  eventName  String   @map("event_name")
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  sourcePage String?  @map("source_page")
  sessionId  String?  @map("session_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventName])
  @@index([createdAt])
  @@map("member_events")
}

model WeeklyRecap {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  weekStartDate         DateTime @map("week_start_date")
  weekEndDate           DateTime @map("week_end_date")
  recapJson             Json     @map("recap_json")
  readinessScoreSnapshot Int?    @map("readiness_score_snapshot")
  goalsSnapshotJson     Json?    @map("goals_snapshot_json")
  generatedAt           DateTime @default(now()) @map("generated_at")
  openedAt              DateTime? @map("opened_at")
  emailedAt             DateTime? @map("emailed_at")
  createdAt             DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStartDate])
  @@index([userId])
  @@map("weekly_recaps")
}

model PathwayStepProgress {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  pathwayId  String    @map("pathway_id")
  stepIndex  Int       @map("step_index") // 0-based index into pathway steps
  stepTitle  String    @map("step_title")
  status     String    @default("pending") // pending, in_progress, completed
  completedAt DateTime? @map("completed_at")
  notes      String?   @db.Text
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pathwayId, stepIndex])
  @@index([userId])
  @@map("pathway_step_progress")
}

model TrainingAccessRequest {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  providerKey String   @map("provider_key") // coursera, linkedin_premium
  status      TrainingAccessStatus @default(PENDING)
  requestedAt DateTime @default(now()) @map("requested_at")
  approvedAt  DateTime? @map("approved_at")
  activatedAt DateTime? @map("activated_at")
  rejectedAt  DateTime? @map("rejected_at")
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerKey])
  @@index([userId])
  @@index([status])
  @@map("training_access_requests")
}

enum TrainingAccessStatus {
  PENDING
  APPROVED
  ACTIVE
  IN_PROGRESS
  COMPLETED
  NEEDS_ATTENTION
  REJECTED
}

model AutomationRule {
  id                String   @id @default(uuid())
  ruleKey           String   @unique @map("rule_key")
  triggerEvent      String   @map("trigger_event")
  triggerConditions Json?    @map("trigger_conditions_json")
  actionType        String   @map("action_type")
  actionPayload     Json?    @map("action_payload_json")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("automation_rules")
}

model AIToolResult {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  toolType     AIToolType   @map("tool_type")
  inputSummary String       @map("input_summary")
  output       String       @db.Text
  createdAt    DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, toolType])
  @@map("ai_tool_results")
}

enum AIToolType {
  resume_rewriter
  cover_letter
  interview_practice
  linkedin_headline
  linkedin_about
  job_match_scorer
  salary_negotiation
  gap_analyzer
}

model UserCertification {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  certName   String   @map("cert_name")
  earnedAt   DateTime @map("earned_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, certName])
  @@index([userId])
  @@map("user_certifications")
}

model BlogPost {
  id          String    @id @default(uuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String    @db.Text
  coverImage  String?   @map("cover_image")
  authorName  String    @default("WorkforceAP Team") @map("author_name")
  published   Boolean   @default(false)
  publishedAt DateTime? @map("published_at")
  scheduledAt DateTime? @map("scheduled_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  category    String?

  @@index([published])
  @@index([category])
  @@map("blog_posts")
}


// --- Partner Portal ---

model Partner {
  id           String    @id @default(uuid())
  name         String
  slug         String    @unique  // e.g. "workforce-solutions-austin"
  logoUrl      String?   @map("logo_url")
  contactName  String?   @map("contact_name")
  contactEmail String?   @map("contact_email")
  contactPhone String?   @map("contact_phone")
  active       Boolean   @default(true)
  notes        String?   @db.Text  // internal admin notes
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  counselors   Counselor[]
  referrals    PartnerReferral[]
  partnerUsers PartnerUser[]
  subgroups    Subgroup[]

  @@map("partners")
}

model PartnerUser {
  id        String   @id @default(uuid())
  partnerId String   @map("partner_id")
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@map("partner_users")
}

model Counselor {
  id        String   @id @default(uuid())
  partnerId String   @map("partner_id")
  userId    String   @unique @map("user_id")  // links to User (must have role = counselor)
  title     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  partner     Partner               @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments CounselorAssignment[]

  @@index([partnerId])
  @@map("counselors")
}

model CounselorAssignment {
  id          String   @id @default(uuid())
  counselorId String   @map("counselor_id")
  memberId    String   @map("member_id")  // User.id of the student
  assignedAt  DateTime @default(now()) @map("assigned_at")
  active      Boolean  @default(true)
  notes       String?  @db.Text

  counselor Counselor @relation(fields: [counselorId], references: [id], onDelete: Cascade)
  member    User      @relation("MemberAssignments", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([counselorId, memberId])
  @@index([counselorId])
  @@index([memberId])
  @@map("counselor_assignments")
}

model PartnerReferral {
  id         String   @id @default(uuid())
  partnerId  String   @map("partner_id")
  memberId   String   @map("member_id")
  referredAt DateTime @default(now()) @map("referred_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  member  User    @relation("MemberReferrals", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([partnerId, memberId])
  @@index([partnerId])
  @@map("partner_referrals")
}

// --- Member Subgroups (partner/manager/church visibility) ---

enum SubgroupType {
  partner
  manager
  church
}

enum MemberSubgroupAssignmentType {
  auto_referral
  manual_admin
  manual_leader
}

model Subgroup {
  id          String       @id @default(uuid())
  name        String
  type        SubgroupType
  leaderId    String       @map("leader_id")
  partnerId   String?      @map("partner_id") // optional: for type=partner, links to Partner for auto-assignment
  description String?      @db.Text
  createdAt   DateTime     @default(now()) @map("created_at")
  createdBy   String       @map("created_by")

  leader   User              @relation("SubgroupLeader", fields: [leaderId], references: [id], onDelete: Restrict)
  creator  User              @relation("SubgroupCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  partner  Partner?          @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  members  MemberSubgroup[]
  leaders  SubgroupLeader[]
  invitations Invitation[]

  @@index([type])
  @@index([leaderId])
  @@index([partnerId])
  @@map("subgroups")
}

model MemberSubgroup {
  id             String                     @id @default(uuid())
  memberId       String                     @map("member_id")
  subgroupId     String                     @map("subgroup_id")
  assignedAt     DateTime                   @default(now()) @map("assigned_at")
  assignedBy     String?                    @map("assigned_by")
  assignmentType MemberSubgroupAssignmentType @map("assignment_type")

  member   User     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  subgroup Subgroup @relation(fields: [subgroupId], references: [id], onDelete: Cascade)
  assigner User?    @relation("MemberSubgroupAssigner", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@unique([memberId, subgroupId])
  @@index([memberId])
  @@index([subgroupId])
  @@map("member_subgroups")
}

model SubgroupLeader {
  id         String   @id @default(uuid())
  subgroupId String  @map("subgroup_id")
  userId     String  @map("user_id")
  role       String  @default("secondary") // primary, secondary
  addedAt    DateTime @default(now()) @map("added_at")

  subgroup Subgroup @relation(fields: [subgroupId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([subgroupId, userId])
  @@index([subgroupId])
  @@index([userId])
  @@map("subgroup_leaders")
}

// --- Pipeline & Placement Tracking ---

model PlacementRecord {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  employerName  String    @map("employer_name")
  jobTitle      String    @map("job_title")
  startDate     DateTime? @db.Date @map("start_date")
  salaryOffered Int?      @map("salary_offered") // annual, in whole dollars
  placedAt      DateTime  @default(now()) @map("placed_at")
  placedBy      String?   @map("placed_by") // counselor or admin userId
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([placedAt])
  @@map("placement_records")
}

model CounselorNote {
  id        String   @id @default(uuid())
  memberId  String   @map("member_id")
  authorId  String   @map("author_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  member User @relation("MemberNotes", fields: [memberId], references: [id], onDelete: Cascade)
  author User @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([authorId])
  @@map("counselor_notes")
}
model AuditLog {
  id           String   @id @default(uuid())
  actorUserId  String?  @map("actor_user_id")
  action       String
  targetType   String   @map("target_type")
  targetId     String?  @map("target_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  actor User? @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// --- Admin Invitations ---

enum InvitationRole {
  admin
  partner
  member
}

enum InvitationStatus {
  pending
  accepted
  expired
  revoked
}

model Invitation {
  id              String           @id @default(uuid())
  email           String           @db.Text
  role            InvitationRole
  subgroupId      String?          @map("subgroup_id")
  programSlug     String?          @map("program_slug")
  invitedById     String           @map("invited_by")
  token           String           @unique
  status          InvitationStatus @default(pending)
  personalMessage String?         @map("personal_message") @db.Text
  expiresAt      DateTime         @map("expires_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  acceptedAt      DateTime?        @map("accepted_at")
  acceptedById    String?          @map("accepted_by")

  invitedBy  User  @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedBy User? @relation("InvitationAccepter", fields: [acceptedById], references: [id], onDelete: SetNull)
  subgroup   Subgroup? @relation(fields: [subgroupId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([token])
  @@index([status])
  @@index([invitedById])
  @@index([expiresAt])
  @@map("invitations")
}

// --- Employer Portal & Job Management ---

model Employer {
  id                 String    @id @default(uuid())
  userId             String    @unique @map("user_id")
  companyName        String    @map("company_name")
  companyWebsite     String?   @map("company_website")
  companyDescription String?   @map("company_description")
  logoUrl            String?   @map("logo_url")
  contactName        String    @map("contact_name")
  contactEmail       String    @map("contact_email")
  contactPhone       String?   @map("contact_phone")
  status             String    @default("active") // active, inactive
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]

  @@map("employers")
}

enum JobLocationType {
  remote
  hybrid
  onsite
}

enum JobTypeEnum {
  fulltime
  parttime
  contract
}

enum JobStatusEnum {
  draft
  pending
  approved
  live
  filled
  closed
}

model Job {
  id                     String          @id @default(uuid())
  employerId             String          @map("employer_id")
  title                  String
  location               String?
  locationType           JobLocationType @default(onsite) @map("location_type")
  jobType                JobTypeEnum     @default(fulltime) @map("job_type")
  salaryMin              Int?            @map("salary_min")
  salaryMax              Int?            @map("salary_max")
  description            String          @db.Text
  requirements           String[]        @default([])
  preferredCertifications String[]       @default([]) @map("preferred_certifications")
  suggestedPrograms      String[]        @default([]) @map("suggested_programs")
  status                 JobStatusEnum   @default(draft)
  applicationsCount      Int             @default(0) @map("applications_count")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")
  approvedAt             DateTime?       @map("approved_at")
  approvedById            String?         @map("approved_by")

  employer   Employer   @relation(fields: [employerId], references: [id], onDelete: Cascade)
  approvedBy User?      @relation("JobApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  applications JobPostingApplication[]
  aiMatches  AIJobMatch[]

  @@index([employerId])
  @@index([status])
  @@map("jobs")
}

enum JobPostingApplicationStatus {
  pending
  reviewing
  interview
  offered
  hired
  rejected
}

model JobPostingApplication {
  id          String                    @id @default(uuid())
  jobId       String                    @map("job_id")
  studentId   String                    @map("student_id")
  status      JobPostingApplicationStatus @default(pending)
  coverLetter String?                   @map("cover_letter") @db.Text
  resumeUrl   String?                   @map("resume_url")
  appliedAt   DateTime                  @default(now()) @map("applied_at")

  job    Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([jobId, studentId])
  @@index([jobId])
  @@index([studentId])
  @@map("job_posting_applications")
}

enum AIJobMatchStatus {
  suggested
  employer_notified
  student_notified
  rejected
}

model AIJobMatch {
  id          String         @id @default(uuid())
  jobId       String         @map("job_id")
  studentId   String         @map("student_id")
  matchScore  Int            @map("match_score")
  matchReasons String[]      @default([]) @map("match_reasons")
  status      AIJobMatchStatus @default(suggested)
  createdAt   DateTime       @default(now()) @map("created_at")

  job    Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([jobId, studentId])
  @@index([jobId])
  @@index([studentId])
  @@map("ai_job_matches")
}



